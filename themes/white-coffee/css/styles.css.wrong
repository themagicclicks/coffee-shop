    margin-bottom: 16px;
    padding: 12px 14px;
    border-radius: 14px;
    color: #4a3526;
}
.order-status-banner.is-open {
    background: #f5efe8;
}
.order-status-banner.is-confirmed {
    background: #fff3cd;
}
.order-status-banner.is-paid {
    background: #fce8e6;
}
.order-items-list {
    list-style: none;
    margin: 0 0 18px;
    padding: 0;
}
.stored-order-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid rgba(0,0,0,0.08);
}
.stored-order-item__main {
    min-width: 0;
}
.stored-order-item__title {
    font-weight: 700;
    color: #1c130d;
}
.stored-order-item__meta {
    color: #6f5846;
}
.stored-order-item__side {
    display: flex;
    align-items: center;
    gap: 8px;
}
.empty-order {
    padding: 16px 0;
    color: #6f5846;
}
.order-modal__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
}
.order-modal__total {
    font-size: 1.2rem;
    color: #1c130d;
}
.order-modal__actions {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
}
.order-modal__actions--end {
    justify-content: flex-end;
}
