.order-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.55);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
}
.order-modal {
    background: #fff;
    color: #1c130d;
    border-radius: 20px;
    padding: 24px;
    box-shadow: 0 24px 60px rgba(0,0,0,0.25);
    position: relative;
    width: min(560px, 100%);
    max-height: 90vh;
    overflow: auto;
}
.order-modal--compact {
    width: min(420px, 100%);
}
.order-modal__close {
    position: absolute;
    top: 10px;
    right: 10px;
    border: 0;
    background: transparent;
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
    color: #6f5846;
}
.order-modal__title {
    margin: 0 0 6px;
    color: #1c130d;
}
.order-modal__subtitle {
    margin: 0 0 18px;
    color: #6f5846;
}
.order-modal__item-name {
    font-weight: 700;
    margin-bottom: 16px;
    color: #1c130d;
}
.order-qty-picker {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
}
.order-qty-picker__button {
    border: 1px solid #d7c8bb;
    border-radius: 12px;
}
.order-qty-picker__input {
    width: 84px !important;
    text-align: center;
    border: 1px solid #d7c8bb !important;
    border-radius: 12px !important;
    height: 44px !important;
    margin: 0 !important;
}
