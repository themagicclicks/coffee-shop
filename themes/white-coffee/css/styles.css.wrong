}
.menu-pdf-kicker {
    font-size: 3.4mm;
    letter-spacing: 1.2mm;
    text-transform: uppercase;
    margin-bottom: 2.5mm;
}
.menu-pdf-header h1 {
    margin: 0;
    font-size: 11mm;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.8mm;
}
.menu-pdf-header p {
    margin: 3mm auto 0;
    max-width: 118mm;
    font-size: 3.4mm;
    line-height: 1.5;
}
.menu-pdf-body {
    column-count: 2;
    column-gap: 10mm;
    margin-top: 6mm;
}
.menu-pdf-section {
    break-inside: avoid;
    page-break-inside: avoid;
    margin-bottom: 6mm;
}
.menu-pdf-section h2 {
    margin: 0 0 3mm;
    font-size: 6.5mm;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 0.4mm;
    border-bottom: 1px solid rgba(43, 33, 26, 0.25);
    padding-bottom: 2mm;
}
.menu-pdf-items {
    list-style: none;
    margin: 0;
    padding: 0;
}
.menu-pdf-item {
    display: flex;
    justify-content: space-between;
    gap: 4mm;
    align-items: flex-start;
    padding: 2.2mm 0;
    border-bottom: 1px dotted rgba(43, 33, 26, 0.18);
    break-inside: avoid;
    page-break-inside: avoid;
}
.menu-pdf-item__main {
    flex: 1;
}
.menu-pdf-item__main h3 {
    margin: 0;
    font-size: 4.1mm;
    line-height: 1.2;
    text-transform: uppercase;
}
.menu-pdf-item__main p {
    margin: 1.2mm 0 0;
    font-size: 3mm;
    line-height: 1.4;
    color: #5b4b40;
}
.menu-pdf-item__price {
    min-width: 16mm;
    text-align: right;
    font-size: 4mm;
    font-weight: bold;
}
.menu-pdf-footer {
    margin-top: 7mm;
    break-inside: avoid;
    page-break-inside: avoid;
}
.menu-pdf-footer__band {
    background: #2b211a;
    color: #fff;
    border-radius: 6mm;
    padding: 4mm 6mm;
    display: flex;
    justify-content: space-between;
    gap: 6mm;
    align-items: center;
}
.menu-pdf-footer__logo {
    width: 30mm;
    max-width: 100%;
}
.menu-pdf-footer__band span {
    font-size: 3mm;
    letter-spacing: 0.5mm;
    text-transform: uppercase;
}
@media (max-width: 768px) { 

	.hero{
		background-image: unset;
	}
	body > .vertical-spacer:first-child{
		display:none;
	}
	.container {
		width: 90%;
		opacity: 0.2;
		filter: blur(3px);
		transition: opacity 2s ease, filter 2s ease;
	}
	.block-first .container {
		min-height: 220vh;
	}
	.coffee-banner .container.show {
		min-height: 120vh;
	}
	div.customers .container.show {
		min-height: auto;
	}
	.homevideo .container.show {
		min-height: auto;
		float: left;
		margin: 0 0 40px 0;
		width: 100%;
		padding: 5%;
		box-sizing: border-box;
	}
	.row.all-pages h1.logo {
		height: auto;
		position: relative;
		float: left;
		padding: 20px 0;
	}
	.row.all-pages h1.logo img {
		width: 100%;
		position: relative;
	}
	.row.all-pages{
		height:auto;
	}
	.caption-box {
		width: 100%;
		margin: 0;
		padding: 0;
		font-size: 1.5rem;
		height: auto;
		transform: unset;
		margin: 20px 0;
		text-align: center;
	}
	
	.htmlslider ul li{
		position:relative;
	}
	div.slider-div{
		margin-top:40px;
		position:relative;
	}
	h2.sublogo {
		position: absolute;
		top: 0;
		font-size: 1.4rem;
		text-align: center;
		width: 100%;
		margin: 0;
	}
	div.events ul li {
		margin: 10px 0;
		width: 100% !important;
	}
	
	div.row.coffee-banner {
		background-image: none;
	}
	a.transparent-image{
		
	}
	a.transparent-image img {
		width: 100%;
	}
	a.link-text {
		position: absolute;
		top: -58px;
		right: 0;
		text-align: right;
		font-size: 2.5rem;
		height: 80px;
		line-height: 40px;
		background-size: auto 80%;
	}
	div.coffee-banner div.left, div.coffee-banner div.right{
		min-height:auto;
	}
	div.coffee-banner div.vertical-spacer, div.coffee-banner div.vertical-spacer, div.homevideo div.vertical-spacer, div.home-shop div.vertical-spacer{
		height:0 !important;
	}
	div.banner h3 {
		margin: 0;
		padding: 0;
		text-align: center;
		font-weight: bold;
		text-shadow: 2px 2px 3px #000;
	}
	div.banner div.image {
		margin: 0;
		width: 100%;
	}
	div.banner div.image img {
		top: 0;
		left: 0;
		width: 100%;
		position: absolute;
	}
	div.homevideo h2 {
		text-align: center;
	}
	div.homevideo .logo img {
		left: 0;
	}
	.block-first div.left{
		min-height:auto;
	}
	div.homevideo div.video {
		height: auto;
	}
	ul.bespokeproducts, ul.shopproducts{
		margin:40px 0;
	}
	ul.bespokeproducts li, ul.shopproducts li{
		width:100% !important;
	}
	ul.customers-promo li {
		text-align: left;
		text-indent: 0;
		line-height: 30px !important;
	}
	ul.customers-promo li {
		text-align: left;
		text-indent: 0;
		line-height: 30px !important;
	}
	div.shop div.shopmessage{
		height: auto;
		padding:0;
	}
	div.shop div.shopmessage a{
		position: relative;
	}
	div.shop div.shopmessage a img {
		position: relative;
		width: 100%;
		margin: 0;
		top: 0;
		transform: unset;
	}
	div.reviews h2 {
		font-size: 3.5rem;
		text-align: center;
		padding: 0;
		margin: 0;
	}
	div.shop div.caption h2{
		font-size:8rem;
	}
	div.shop div.caption h3{
		font-size:3.5rem;
	}
	.page-footer .logo {
		margin: 0 !important;
		height: auto !important;
		padding: 0 !important;
		text-align: center;
		height: auto;
	}
	.page-footer .logo img {
		top: 0;
		width: 80%;
		left: 0;
		position: relative;
	}
	.spiralreverse.coffee::before{
		display:none;
	}
	article.content-article h1, article.content-article h2, article.content-article h3, article.content-article p, article.content-article strong {
		color: #FFF !important;
	}
	.meta {
		color: #FFF;
	}
	figcaption, figure, main {
		color: #FFF;
	}
	.feature-list h5 {
		text-align: left;
		margin: 0;
		font-size: 3rem;
		
	}
	div.feature-list ul li {
		font-size: 1.4rem;
		line-height: 26px !important;
	
	}
	.btn.large{
		width: auto;
	}
	.open-menu {
		width: 74%;
		left: 4%;
		top: 7%;
	}
	.open-cart.active {
		width: 90%;
		left: 5%;
		top: 160px;
	}
	.open-cart::after {
		transform: rotate(-90deg);
		right: 100px;
		top: -21px;
	}
	.open-cart img {
		width: 100%;
		
	}
	.open-cart h5 {
		position: relative;
		margin: 10px 0;
		text-align: center;
		right: unset;
		top: unset;
		width: 100%;
	}
	.open-cart .btn {
		width: 80%;
		margin: 10px 10%;
	}
	figure {
		height: auto;
	}
	div.menu-section{
		width:100% !important;
	}
	.menu-download-row {
		text-align: center;
	}
	ul.menu-section-list li a h5{
		overflow:hidden;
	}
}

@media only screen and (max-width: 600px) {
    .order-modal-overlay {
        padding: 16px;
    }
    .order-modal {
        padding: 20px 18px;
    }
    .order-modal__footer,
    .stored-order-item {
        align-items: flex-start;
        flex-direction: column;
    }
    .stored-order-item__side,
    .order-modal__actions,
    .order-modal__actions--end,
    .order-qty-picker {
        width: 100%;
    }
.order-modal__actions {
    justify-content: flex-start;
}

.paypal-demo-checkout {
    background: #fff;
    border-radius: 16px;
    padding: 24px;
    margin-top: 20px;
}

.paypal-demo-card,
.paypal-demo-summary {
    background: #f8f5ef;
    border: 1px solid rgba(22, 41, 60, 0.12);
    border-radius: 16px;
    padding: 24px;
}

.paypal-demo-addresses {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin-top: 20px;
}

.paypal-demo-address h6 {
    margin: 0 0 10px 0;
    font-weight: bold;
}

.paypal-demo-summary {
    text-align: center;
}

.paypal-demo-summary__brand {
    display: inline-block;
    padding: 8px 14px;
    border-radius: 999px;
    background: #003087;
    color: #fff;
    font-weight: bold;
    margin-bottom: 14px;
}

.paypal-demo-summary__total {
    font-size: 2.4rem;
    font-weight: bold;
    margin: 20px 0;
    color: #003087;
}

.paypal-demo-summary__note {
    margin-top: 14px;
    color: #6f5846;
}
}
