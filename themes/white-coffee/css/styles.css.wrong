.btn-large i {
    margin-right: 8px;
}
.hamburger {
	width: 40px;
	height: 30px;
	display: flex;
	flex-direction: column;
	justify-content: space-between;
	cursor: pointer;
	position: absolute;
	right: 0;
	top: 50%;
	transform: translateY(-50%);
}

.bar {
  height: 4px;
  background: white;
  border-radius: 2px;
  transition: all 0.8s ease;
}
.bar.dark{
    background-color: #16293c !important;
}
/* Hover animation: shrink width */
.hamburger:hover .bar:nth-child(1) {
  width: 60%;
  margin-left: auto;
  transition: all 0.8s ease;
}

.hamburger:hover .bar:nth-child(2) {
  width: 80%;
  margin-left: auto;
  transition: all 0.8s ease;
}

.hamburger:hover .bar:nth-child(3) {
  width: 60%;
  margin-left: auto;
  transition: all 0.8s ease;
}

/* Active state for X shape */
.hamburger.active .bar:nth-child(1) {
	transform: rotate(45deg) translate(13px, 12px);
	width: 100%;
}

.hamburger.active .bar:nth-child(2) {
  opacity: 0;
  transform: translateX(-20px);
}

.hamburger.active .bar:nth-child(3) {
  transform: rotate(-45deg) translate(5px, -5px);
  width: 100%;
}
.open-menu {
	position: absolute;
	top: 106px;
	right: 16%;
	width: 360px;
	height: auto;
	background: white;
	border-radius: 16px;
	box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
	padding: 30px 20px;
	display: none;
	flex-direction: column;
	z-index: 1000;
	transition: transform 0.3s ease, opacity 0.3s ease;
	padding: 20px 20px 20px 20px;
}

.open-menu.active {
  display: flex;
}
.open-menu::after {
	content: "";
	width: 0px;
	height: 0px;
	border-style: solid !important;
	border-width: 12.5px 0 12.5px 21.7px !important;
	border-color: transparent transparent transparent #FFFFFF !important;
	transform: rotate(0deg);
	position: absolute;
	right: -20px;
	top: 18px;
}
.open-menu img {
	width: 240px;
	position: relative;
	/* float: left; */
	display: block;
	margin: 0 auto;
}

.open-menu a {
	text-decoration: none;
	color: #000;
	font-weight: 600;
	/* margin: 12px 0; */
	font-family: 'Poppins', sans-serif;
	font-size: 1.4rem;
	margin: 10px 0;
	transition: all 0.4s;
}
.open-menu a::after {
	content: "";
	width: 0;
	height: 4px;
	background-color: #cbb1a7;
	position: relative;
	display: block;
	transition: all 0.4s;
}
.open-menu a:hover {
  color: #cbb1a7;
  transition: all 0.4s;
}
.open-menu a:hover:after{
    content:"";
    width: 60%;
    transition: all 0.4s;
}


.open-cart {
	position: absolute;
	top: 100px;
	right: 22%;
	width: 550px;
	height: auto;
	background: white;
	border-radius: 16px;
	box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
	/* padding: 30px 20px; */
	display: none;
	flex-direction: column;
	z-index: 1000;
	transition: transform 0.3s ease, opacity 0.3s ease;
	padding: 20px 20px 20px 20px;
	min-height: 500px;
}

.open-cart.active {
  display: flex;
}
.open-cart::after {
	content: "";
	width: 0px;
	height: 0px;
	border-style: solid !important;
	border-width: 12.5px 0 12.5px 21.7px !important;
	border-color: transparent transparent transparent #FFFFFF !important;
	transform: rotate(0deg);
	position: absolute;
	right: -20px;
	top: 18px;
}
.open-cart img {
