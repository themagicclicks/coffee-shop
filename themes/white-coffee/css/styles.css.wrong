/* Import Google Material Icons */
@import url('https://fonts.googleapis.com/icon?family=Material+Icons');

/* General Body Styling */
body {
    font-family: "Open Sans", serif;
    font-size:14px;
    background-color: #16293c;
    overflow-x:hidden;
   
}
.hero {
	/* height: 60vh; */
	background-image: url('../../../images/coffee-shop-hero-final.webp');
	background-position: 0 -15vh;
	background-size: 100% auto;
	background-repeat: no-repeat;
	background-blend-mode: soft-light;
	background-attachment: fixed;
}

.hero.bg-scroll {
	background-attachment: scroll;
}
div.reviews div.review a.rating i.small {
	color: #ffc350;
}
.hidden{
    display:none;
}
.no-background{
    background-color:transparent;
    background: unset;
}
div.slider-div{
    position: relative;
    width: 100%;
    padding-top: 56.25%;
    overflow: hidden;
}
nav ul a{
	color:#fff !important;
}
div.slider-div > *{
    position: absolute;
    top:0;
    left:0;
    width:auto;
    height:100%;
}
div.slider-div > video {
   top:-12px;
}
div.slider-div {
	border: 20px solid #3A2E2E;
	background-color:#3A2E2E;
	border-radius: 10px;
}

.browser-default, p {
	font-size: 1.2rem;
}
nav {
	box-shadow: none !important;
	margin: 0;
	padding: 0;
	position: relative;
	float: left;
}
.collection{
    	box-shadow: none !important;
}
nav .nav-wrapper {
	
	z-index: 999;
}
nav ul a{
    font-size:1.4rem;
}
nav ul a:hover {
	background-color: #544442EB;
	border-radius: 4px;
}
nav ul a.dark:hover {
	background-color: #4F6C97EB;
	border-radius: 4px;
	color: #e1f5fe !important;
}
.navy {
	background-color: #16293c;
	box-shadow: unset;
}
.cobalt{
    background-color:#1C53A3;
}
.sky{
    background-color:#3777FF;
}
.dark {
	color: #16293c !important;
}
.container {
    width: 75%;
    max-width:1920px;
    position: relative;
    /*display: flex;*/
    opacity: 0.2;
    filter: blur(3px); /* Apply blur effect */
    transition: opacity 2s ease, filter 2s ease; /* Smooth transition */
}
.coffee{
    background-color:#BAA292;
}
.spiralreverse.coffee {
	position: relative;
}
.spiralreverse.coffee::before{
	content: "";
	width: 0;
	height: 0;
	border-style: solid;
	border-width: 92px 2500px 0px 92px;
	border-color: transparent #BAA292 transparent transparent;
	transform: rotate(0deg);
	right: 0;
	top: -80px;
	position: absolute;
}
.dark-coffee{
    background-color:#3A2E2E;
}
.black-coffee{
    background-color:#181313;
}
div.quote div.container{
    padding:0;
    width:100%;
}
.container.show{
    opacity: 1;
    filter: blur(0); /* Apply blur effect */
    transition: opacity 3s ease, filter 3s ease; /* Smooth transition */
}
.container .left{
    transform: translateX(-600px);
    /*transition: transform 2s ease-in-out;*/
}
.container .right{
    transform: translateX(600px);
    /*transition: transform 2s ease-in-out;*/
}
.container .full{
    transform: translateY(900px);
    /*transition: transform 2s ease-in-out;*/
}
.container.show .left,.container.show .right{
    transform: translateX(0);
    transition: transform 2s ease-in-out;
}
.container.show .full{
     transform: translateY(0);
    transition: transform 2s ease-in-out;
}
.vertical-spacer {
	position: relative;
	height: 50px;
	width: 100%;
	float: left;
}
.more-menu {
	/* float: right; */
	width: 60px;
	height: 60px;
	font-size: 2rem;
	overflow: hidden;
	text-indent: -999px;
	background-image: url("../images/hamburger-white.png");
	background-size: 40px auto;
	padding: 10px;
	box-sizing: border-box;
	background-repeat: no-repeat;
	background-position: center;
	position: absolute;
	right: 0;
}
.topnav{
    font-size:  1.2rem;
    text-transform:uppercase;
}
.block-first{
   min-height: calc(100vh - 110px);
}
.block-first .container{
	/*background-image: url("../images/blue-dotty-spiral.png"), url("../images/blue-wavy-pattern.png");
	background-size: 60% auto, 40% auto;
	background-repeat: no-repeat, no-repeat;
	background-position: left top, right top;*/
	min-height: calc(100vh - 110px);
}
.container.product-page{
	background-image: url("../images/blue-dotty-spiral.png");
	background-size: 60% auto;
	background-repeat: no-repeat;
	background-position: left top;
	min-height: calc(100vh - 110px) !important;
	color:#FFF;
	font-size:1.2rem;
	line-height:30px;
}
.block-first div.left {
	min-height: calc(100vh - 110px);
	/*background-image: url("../images/blue-dotty-spiral.png");
	background-size: 98% auto;
	background-repeat: no-repeat;
	background-position: center;*/
	/*background-blend-mode: color;*/
}
.block-first div.right {
	min-height: calc(100vh - 110px);
	/*background-image: url("../images/blue-wavy-pattern.png");
	background-size: 98% auto;
	background-repeat: no-repeat;
	background-position: top;*/
	/* background-blend-mode: color; */
}
div.row.list-page {
	background-image: url("../images/blue-dotty-spiral.png"), url("../images/blue-wavy-pattern.png");
	background-size: auto, auto;
	background-repeat: no-repeat, no-repeat;
	background-position: left top, right bottom;
}
.block{
    min-height:100vh;
}
.block-first.row, .block.row{
    margin-bottom:0;
}
.quote.productpage{
    background-image: url("../images/blue-wavy-pattern.png");
	background-size: 98% auto;
	background-repeat: no-repeat;
	background-position: top;
}
.quote h2 {
	color: #FFF;
	font-size: 3.6rem;
	text-transform: uppercase;
	font-weight: bold;
}
div.homepagequoteformselect input:not(.select-month input):not(.select-year input),
div.homepagequoteformselect textarea {
    color: white !important; 
}

.homepagequoteformselect .select-wrapper .caret{
    filter:invert(100);
}
.homepagequoteformselect span.character-counter{
    color: white !important;  /* Force font color */
}
h1.logo {
	position: absolute;
	width: 60%;
	color: #fff;
	font-weight: bold;
	font-style: italic;
	font-size: 5rem;
	bottom: 148px;
}
h1.logo img {
	position: absolute;
	top: -98px;
	left: -40px;
}
h1.page-title {
	text-transform: uppercase;
	font-size: 5rem;
	height: 100px;
	line-height: 50px !important;
	/* padding: 0; */
	/* margin: 0; */
	box-sizing: border-box;
	font-weight: 400;
	color:#FFF;
}
h2.sublogo {
	color: #fff;
	font-size: 2rem;
	width: 100%;
	position: relative;
	margin: 10px 20px;
	font-weight: bold;
}
.htmlslider {
	width: 100%;
	height: auto;
	overflow: hidden;
	position: relative;
	float: left;
	z-index:0;
}
.htmlslider ul {
	width: 100%;
	height: 100%;
	list-style: none;
	position: relative;
	float: left;
	/* position: relative; */
	/* min-width: 100%; */
}
.htmlslider ul li {
	list-style: none;
	width: 100%;
	height: 100%;
	z-index: 0;
	float: left;
	position: relative;
	display:none;
	opacity: 0;
	transition: opacity 0.6s ease;
}
.htmlslider ul li.active {
  opacity: 1;
  z-index: 1;
}
.htmlslider ul li:first-child {
	list-style: none;
	width: 100%;
	height: 100%;
	z-index: 1;
	opacity: 1;
	float: left;
	position: relative;
	display: block;
	transition: opacity 0.6s ease;
}
div.events ul li {
	margin: 10px 0 10px 10px;
	width: calc(100% - 30px) !important;
	border-radius: 6px;
	padding: 10px !important;
	box-sizing: border-box;
	transition: all 1s;
}
div.events ul li:hover{
    background-color:#6a4e30;
    transition: all 1s;
}
.snippet-container {
	position: relative;
	display: block;
	float: left;
	width: 100%;
	height: auto;
}
.collection, .collection .collection-item{
    border:0;
    background:none;
}
div.events {
	display: block;
	padding: 0;
	float: left;
}
div.events span strong, div.events small{
	color:#FFFFFF;
}
div.events small{
	font-size:1.2rem;
}
.datepicker-modal, .timepicker-modal {
    position: fixed !important;
    z-index: 9999 !important;
}
div.block.spiral {
	background-image: url("../images/blue-dotted-spiral-pattern.png");
	background-position: right;
	background-size: 60% auto;
	background-blend-mode: overlay;
	background-repeat: no-repeat;
}
div.block.spiralreverse {
	background-image: url("../images/blue-dotted-spiral-pattern.png");
	background-position: left top;
	background-size: 60% auto;
	background-blend-mode: multiply;
	background-repeat: no-repeat;
}
div.block.spiral-tail {
	background-image: url("../images/blue-dotted-spiral-pattern.png");
	background-position: -80px center;
	background-size: 60% auto;
	background-blend-mode: overlay;
	background-repeat: no-repeat;
}
a.square-photo {
	position: relative;
	display: block;
	width: 100%;
	height: 0;
	overflow: hidden;
	padding: 100% 0 0 0;
	box-sizing: border-box;
	transition: all 0.5s;
}
a.transparent-image {
	position: relative;
	display: block;
	width: 100%;
	height: 0;
	overflow: visible;
	padding: 100% 0 0 0;
	box-sizing: border-box;
	transition: all 0.5s;
}
a.square-photo:hover{
    transition: all 0.5s;
    box-shadow:0 0 15px rgba(255,255,255,0.9);
}
a.square-photo img {
	position: absolute;
	display: block;
	width: 100%;
	height: 100%;
	top: 0;
}
a.transparent-image img {
	position: absolute;
	display: block;
	width: 200%;
	height: auto;
	top: 0;
	left: -40%;
}
a.link-text {
    position: relative;
    display: block;
    background-image: url("../images/go-button.png");
    width: 100%;
    height: 80px;
    margin: 20px 0;
    background-repeat: no-repeat;
    background-position: right;
    background-size: auto 100%;
    padding: 0 90px 0 0;
    color: #FFF;
    font-size: 3.5rem;
    transition: transform 0.5s ease-in-out, text-shadow 0.5s ease-in-out;
}

a.link-text:hover {
    transform: translateX(20px);
    text-shadow: 0px 0px 25px rgba(255, 255, 255, 0.8); /* White glow effect */
}

div.banner h3 {
	position: relative;
	margin: 0 0 0 15%;
	color: #FFF;
}
div.banner div.image{
    position: relative;
	width: 90%;
	height: 0;
	padding: 56% 0 0 0;
	margin: 0 0 0 10%;
}
div.banner div.image img {
	position: absolute;
	top: -30px;
	left: 0;
	width: 85%;
}
div.banner h2 {
	position: relative;
	color: #FFF;
	text-align: right;
	text-transform: capitalize;
	font-size: 4rem;
	width: 70%;
	float: right;
	margin: 0;
}
div.homevideo h2 {
	position: relative;
	font-size: 4rem;
	color: #FFF;
}
div.homevideo .logo {
	position: relative;
	width: 100%;
	bottom: unset;
	margin: 120px 0 0 0;
}
div.homevideo .logo img {
	position: relative;
	width: 90%;
}
div.homevideo .logo span {
	position: absolute;
	display: block;
	top: 170px;
	font-size: 6rem;
}
div.homevideo div.video {
	position: relative;
	width: 100%;
	height: 500px;
	overflow: hidden;
	border-radius: 30px;
}
div.homevideo div.video img {
	position: relative;
	width: 100%;
}
div.homevideo .right h3 {
	position: relative;
	color: #FFF;
	font-size: 2rem;
}
div.homevideo .right p {
	position: relative;
	color: #FFF;
	font-size: 1.4rem;
}
div.products h2{
    color:#FFF;
    font-size:4rem;
}
ul.bespokeproducts,ul.shopproducts {
	position: relative;
	float: left;
	width: 100%;
	height: auto;
	list-style: none;
	margin: 0;
	padding: 0;
}
ul.bespokeproducts li,ul.shopproducts li {
	position: relative;
	float: left;
	width: 25%;
	height: auto;
	overflow: hidden;
	padding: 2%;
	box-sizing: border-box;
}
ul.bespokeproducts.shop li{
    width:33.33%;
}
.col.home-shop ul.shopproducts li{
    width:50%;
}
ul.bespokeproducts li a,ul.shopproducts li a {
	position: relative;
	display: block;
	float: left;
	width: 100%;
}
ul.bespokeproducts li a div,ul.shopproducts li a div {
	position: relative;
	width: 100%;
	height: 0;
	float: left;
	padding: 100% 0 0 0;
	border-radius: 24px;
	overflow: hidden;
}
ul.bespokeproducts li a div img,ul.shopproducts li a div img {
	position: relative;
	width: 101%;
	position: absolute;
	top: 0;
}
ul.bespokeproducts li a:hover div,ul.shopproducts li a:hover div{
    transition: all 0.5s;
    box-shadow:0 0 15px rgba(255,255,255,0.9);
}
ul.bespokeproducts li a h3, ul.shopproducts li a h3 {
	position: relative;
	color: #FFF;
	font-size: 1.4rem;
	width: 100%;
	height: 40px;
	float: left;
	text-align: center;
	margin: 30px 0 0 0;
	overflow: hidden;
	text-overflow: ellipsis;
	white-space: nowrap;
}
ul.bespokeproducts li a h5,ul.shopproducts li a h5 {
	position: relative;
	color: #FFF;
	font-size: 1.2rem;
	width: 100%;
	height: 40px;
	float: left;
	text-align: center;
	margin: 0;
}
ul.bespokeproducts li h5.price,ul.bespokeproducts li h5.vprice,ul.shopproducts li h5.price,ul.shopproducts li h5.vprice {
	position: relative;
	color: #FFF;
	font-size: 1.5rem;
	width: 100%;
	height: 40px;
	float: left;
	text-align: center;
	margin: 0;
	font-weight: bold;
	text-transform: uppercase;
	height: 60px;
	line-height: 60px;
}
ul.shopproducts li h5.net_quantity,ul.bespokeproducts.shop li h5.net_quantity {
	color: #FFF;
	font-weight: bold;
	text-align: center;
	margin: 15px 0 0 0;
	position: relative;
	float: left;
	width: 100%;
}
ul.bespokeproducts li h5.vprice,ul.shopproducts li h5.vprice{
    display:none;
}
a.cart-btn {
	position: absolute;
	right: 80px;
	top: 4px;
}
a.cart-btn.hidden{
    display:none;
}
div.customers {
    float:left;
	background-image: url(../images/barista.png);
	background-size: auto 100%;
	background-repeat: no-repeat;
	background-position: right top;
	background-blend-mode: lighten;
}
div.customers h2{
    color:#fff;
    font-size:4rem;
}
ul.logolist {
	position: relative;
	float: left;
	width: 100%;
	list-style: none;
	margin: 0;
}
ul.logolist li {
	position: relative;
	width: 20%;
	float: left;
	padding: 1%;
	overflow: hidden;
}
ul.logolist li img {
	position: relative;
	max-width: 100%;
	filter: grayscale(90%);
	height: 140px;
	/* width: auto; */
	/* height: auto; */
	transition: all 1s;
}
ul.logolist li img:hover {
    filter: grayscale(0%);;
    transition: all 1s;
}
div.shop {
	float: left;
}
div.shop div.caption h2 {
	position: relative;
	color: #AF7746;
	font-weight: 700;
	font-size: 9rem;
	font-family: Arial Black;
	letter-spacing: -7px;
	text-align: center;
}
div.shop div.caption h3 {
	position: relative;
	-webkit-text-stroke-width: 3px;
	-webkit-text-stroke-color: #F4D9BC;
	font-weight: 700;
	font-size: 4.5rem;
	font-family: Arial Black;
	letter-spacing: -7px;
	color: transparent;
	margin: -57px 0 0 0;
	text-align: center;
}
div.shop div.shopmessage {
	position: relative;
	background-image: url("../images/arrow-pattern.png");
	background-size: 100% auto;
	background-repeat: no-repeat;
	margin: 10%;
	background-position: center top;
	background-blend-mode: color;
	float: left;
	width: 80%;
	height: 0;
	padding: 100% 0 0 0;
}
div.shop div.shopmessage a {
	position: absolute;
	display: block;
	float: left;
	width: 100%;
	top: 0;
}
div.shop div.shopmessage a img {
	position: relative;
	/* float: left; */
	width: 70%;
	margin: 50%;
	transform: translateX(-50%) translateY(-50%);
}
ul.genericproducts {
	position: relative;
	list-style: none;
	float: left;
	margin: 0;
	padding: 0;
	width: 100%;
	height: 700px;
	overflow-y: auto;
}
ul.genericproducts li {
	position: relative;
	width: 100%;
	height: auto;
	margin: 20px 0;
}
ul.genericproducts li a.item{
    position: relative;
}
ul.genericproducts li a.item div {
	position: relative;
	width: 100%;
	height: 0;
	padding: 100% 0 0 0;
	overflow: hidden;
	border-radius: 12px;
}
ul.genericproducts li a.item div img {
	position: absolute;
	top: 0;
	width: 100%;
}
ul.genericproducts li a.desc{
    position: relative;
}
ul.genericproducts li a.desc div{
    position: relative;
}
ul.genericproducts li a.desc div h3{
    position: relative;
}
ul.genericproducts li a.desc div p{
    position: relative;
    color:#fff;
    font-size:1.4rem;
}
ul.genericproducts li a.btn.shopbutton {
	padding: 3% 4%;
	width: 180px;
	height: 40px;
	float: right;
	border-radius: 12px;
	line-height: 0;
	box-sizing: border-box;
	font-weight: bold;
}
div.reviews{
    background-image:url("../images/dotted-pattern.png");
    background-repeat:no-repeat;
    background-position:left;
}
div.reviews h2 {
	position: relative;
	color: #FFF;
	font-size: 4.5rem;
	text-align: center;
	padding: 0 20%;
	box-sizing: border-box;
	margin: 0 0 150px 0;
}
div.reviews div.review{
    position: relative;
}
div.reviews div.review a.rating {
	position: relative;
	text-align: center;
	display: block;
	float: left;
	width: 100%;
	height: 60px;
}
div.reviews div.review p {
	position: relative;
	color: #FFF;
	font-size: 1.8rem;
	display: -webkit-box;
	-webkit-line-clamp: 8;
	-webkit-box-orient: vertical;
	overflow: hidden;
	text-overflow: ellipsis;
	/* height: 300px; */
	width: 100%;
}
div.reviews div.review div.photo {
	position: relative;
	width: 100px;
	height: 100px;
	overflow: hidden;
	border-radius: 50px;
	float: left;
	background-color: #a68466;
	/* text-indent: -999px; */
	overflow: hidden;
	text-align: center;
	line-height: 100px;
	font-weight: bold;
	font-size: 1.2rem;
}
div.reviews div.review div.photo img {
	position: absolute;
	width: 100px;
	top: 0;
	left: 0;
}
div.reviews div.review strong {
	position: relative;
	float: right;
	text-align: left;
	width: calc(100% - 120px);
	color: #FFF;
	font-size: 1.8rem;
	font-style: italic;
	line-height: 100px;
}
.article-card {
  display: block;
  text-decoration: none;
  color: inherit;
  border: 1px solid #eee;
  border-radius: 4px;
  overflow: hidden;
  transition: box-shadow 0.2s ease;
}

.article-card:hover {
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.card-image img {
  display: block;
  width: 100%;
  height: auto;
}

.card-content {
  padding: 12px;
}

.card-title {
  font-size: 1.1rem;
  margin: 0;
}
.page-footer .logo {
	position: relative;
	bottom: unset;
	margin: 20px 0;
	overflow: hidden;
	width: 100%;
	font-size: 3rem;
	height: 300px;
	padding: 70px 20px 0 0;
	text-align: right;
}
.page-footer .logo img {
	top: 0;
	width: 80%;
	left: 0;
}
.page-footer h6{
    font-size: 2.5rem;
}
.page-footer ul li {
	font-size: 1.4rem;
	line-height: 40px;
}
.product-subtitle {
	line-height: 40px;
	font-size: 1.4rem;
	text-transform: uppercase;
}
.all-pages > div {
	height: 100%;
}
.row.all-pages h1.logo {
	position: relative;
	bottom: 0;
	width: 100%;
	margin: 0;
	height: 200px;
}
.row.all-pages h1.logo img {
	top: 20px;
	left: 0;
	width: 70%;
}
.caption-box {
	color: white;
	/* text-align: center; */
	max-width: 100%;
	/* padding: 20px; */
	/* border-radius: 8px; */
	transition: opacity 1s ease-in-out;
	opacity: 0;
	position: relative;
	text-align: right;
	width: 100%;
	float: right;
	padding: 20% 5% 0 0;
	box-sizing: border-box;
	transform: translateY(-50%);
	font-size: 2.4rem;
	font-weight: bold;
}
/*div.slider-div{
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    float: left;
    margin: 0;
    box-sizing: border-box;
    overflow: hidden;
}*/

.row.all-pages {
	height: 240px;
	width:75%;
	max-width:1920px;
	overflow: hidden;
}
ul.specifications {
	background-color: transparent !important;
	border: none !important;
	box-shadow: unset;
}
ul.specifications li{
    background-color:transparent !important;
    border: none !important;
}
ul.specifications li span.title {
	font-size: 1.4rem !important;
	font-weight: bold;
	line-height: 20px;
}
ul.specifications li p {
	line-height: 40px;
	text-transform: uppercase;
}
div.product-group-tabs ul li a {
	font-size: 1.4rem !important;
	text-align: center;
	transition: all 1s;
	position: relative;
	overflow:hidden;
}
div.product-group-tabs ul li a.active,div.product-group-tabs ul li a:hover{
    font-weight:bold;
    transition: all 1s;
}
div.product-group-tabs ul li a::after {
	content: "";
	width: 50%;
	height: 5px;
	background-color: #FFF;
	position: absolute;
	display: block;
	left: 25%;
	bottom: -15px;
	transition: all 0.5s;
}
div.product-group-tabs ul li a.active::after {
	content: "";
	width: 30%;
	height: 5px;
	background-color: #FFF;
	position: absolute;
	display: block;
	left: 35%;
	bottom: 0;
	transition: all 0.5s;
}
div.product-group-tabs ul li a:hover:after {
	content: "";
	width: 30%;
	height: 5px;
	background-color: #FFF;
	position: absolute;
	display: block;
	left: 35%;
	bottom: 0px;
	transition: all 0.5s;
}
div.product-thumb{
    position: relative;
}
div.product-thumb div.img {
	position: relative;
	width: 120px;
	height: 120px;
	background-color: #1e386a;
	border-radius: 50%;
	margin: 0 auto;
	overflow: hidden;
}
div.product-thumb img {
	position: absolute;
	width: 50%;
	left: 50%;
	top: 50%;
	transform: translateX(-50%) translateY(-50%);
	filter: invert(100%);
}
.product-thumb h3 {
	font-size: 1rem;
	text-transform: uppercase;
	text-align: center;
}
.row .col {
	float: left;
	-webkit-box-sizing: border-box;
	box-sizing: border-box;
	padding: 0 .75rem;
	min-height: 1px;
}
.tab-box {
	padding-top: 40px !important;
}
.error-container {
	
	text-align: center;
	max-width: 500px;
	margin: 0 auto;
