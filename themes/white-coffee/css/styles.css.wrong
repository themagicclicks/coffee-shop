}
.error-image {
	background-image: url('https://scyphusdesignstudio.co.uk/paylesspackaging/dev/images/payless-404.png');
	position: absolute;
	width: 400px;
	height: 386px;
	left: calc(50% - 700px);
	background-size: 100% auto;
	background-position-y: 0;
}
.error-code {
    font-size: 9rem;
    font-weight: 700;
    margin: 0;
    color: #26a69a;
}
.error-message {
    font-size: 1.8rem;
